# Environment Variables Configuration
# Copy this file to .env.local and fill in your actual values

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://kenigswap.com

# Supabase Configuration (REQUIRED)
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# CoinGecko API Configuration (REQUIRED for rates page)
# Get your free API key from: https://www.coingecko.com/en/api/pricing
# Without this key, the /rates page will not work properly
COINGECKO_API_KEY=your-api-key-here

# Development Environment
NODE_ENV=production
